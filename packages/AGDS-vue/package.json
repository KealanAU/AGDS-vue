{
  "name": "agds-vue",
  "version": "1.0.0",
  "type": "module",
  "description": "Agriculture Design System (AgDS) — accessible Vue 3 components for the Department of Agriculture, Fisheries and Forestry",
  "keywords": [
    "vue",
    "australia",
    "government",
    "design-system",
    "accessibility",
    "agriculture"
  ],
  "author": "kealanc",
  "license": "MIT",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./styles/tokens": "./src/styles/tokens.css",
    "./styles/base": "./src/styles/base.css",
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.mjs"
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "dev": "unbuild --stub",
    "build": "unbuild",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "reka-ui": "^2.9.0"
  },
  "peerDependencies": {
    "@iconify/vue": ">=5.0.0",
    "@nuxt/kit": ">=3.0.0",
    "nuxt": ">=3.0.0",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "@iconify/vue": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@nuxt/kit": "^3.21.1",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/tsconfig": "^0.8.1",
    "axe-core": "^4.11.1",
    "happy-dom": "^20.8.3",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-tsc": "^3.2.5"
  }
}

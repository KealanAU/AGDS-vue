456,458],{},[19,452,36],{},[19,454,447],{}," — optional action (a second ",[19,457,447],{}," is valid when one term has multiple associated descriptions)",[15,460,461],{},"On narrow viewports the term stacks above the description (column layout). At 768 px and wider they display side-by-side — the term occupies 30 % / minimum 200 px of the width.",[10,463,465],{"id":464},"components","Components",[467,468,469,482],"table",{},[470,471,472],"thead",{},[473,474,475,479],"tr",{},[476,477,478],"th",{},"Component",[476,480,481],{},"Description",[483,484,485,498,510,521,531],"tbody",{},[473,486,487,492],{},[488,489,490],"td",{},[19,491,21],{},[488,493,494,495,497],{},"Root ",[19,496,416],{}," wrapper",[473,499,500,504],{},[488,501,502],{},[19,503,25],{},[488,505,506,507,509],{},"Row ",[19,508,423],{}," — one per key–value pair",[473,511,512,516],{},[488,513,514],{},[19,515,29],{},[488,517,518,520],{},[19,519,439],{}," — the label",[473,522,523,527],{},[488,524,525],{},[19,526,32],{},[488,528,529,448],{},[19,530,447],{},[473,532,533,537],{},[488,534,535],{},[19,536,36],{},[488,538,539,541],{},[19,540,447],{}," — optional trailing action",[15,543,544,545,548],{},"None of the components have props beyond a ",[19,546,547],{},"default"," slot.",[10,550,552],{"id":551},"accessibility","Accessibility",[429,554,555,561,564],{},[432,556,557,558,560],{},"Renders a native ",[19,559,416],{}," so the browser's accessibility tree communicates term/description relationships automatically (WCAG 1.3.1)",[432,562,563],{},"No ARIA roles required — native semantics are sufficient",[432,565,566,567,569,570,573,574,577,578],{},"Action links inside ",[19,568,36],{}," should have descriptive labels that include the field name (e.g. ",[19,571,572],{},"\"Change full name\"",") — use ",[19,575,576],{},"AgDSVisuallyHidden"," to add context if the visible text is just ",[19,579,580],{},"\"Change\"",[10,582,584],{"id":583},"changelog","Changelog",[586,587,589],"h3",{"id":588},"_010","0.1.0",[429,591,59